# Telegram Bot
BOT_TOKEN=REPLACE_WITH_NEW_BOT_TOKEN
ADMIN_ID=REPLACE_WITH_ADMIN_TELEGRAM_ID

# Database
DATABASE_URL=postgresql+asyncpg://postgres:12345678@localhost:5432/homeworkbot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Logging
LOG_LEVEL=INFO

# Features
ALLOW_LATE_SUBMISSION=true
MAX_REVISION_ATTEMPTS=2

# Scheduler
SCHEDULER_TIMEZONE=Asia/Tashkent
REMINDER_24H_ENABLED=true
REMINDER_3H_ENABLED=true

# Broadcast
BROADCAST_THROTTLE_MS=100
BROADCAST_RETRY_ATTEMPTS=3
BROADCAST_RETRY_DELAY_MINUTES=5

# Auth
JWT_SECRET=CHANGE_ME_STRONG_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_REFRESH_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Bot internal
BOT_INTERNAL_TOKEN=CHANGE_ME_INTERNAL_BOT_TOKEN

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
